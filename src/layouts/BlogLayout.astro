---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbList from '../components/BreadcrumbList.astro';
import CTASection from '../components/CTASection.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  pubDate: Date;
  author: string;
  tags: string[];
}

const { title, description, canonicalUrl, pubDate, author, tags } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: title, href: '' },
];
---
<BaseLayout {title} {description} {canonicalUrl}>
  <div class="blog-hero">
    <div class="container-narrow">
      <BreadcrumbList items={breadcrumbs} />
      <h1>{title}</h1>
      <div class="blog-meta">
        <span>By {author}</span>
        <span class="dot">Â·</span>
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {tags.length > 0 && (
          <span class="dot">Â·</span>
          <span class="tags">{tags.join(', ')}</span>
        )}
      </div>
    </div>
  </div>

  <div class="blog-body section">
    <div class="blog-layout container">
      <article class="prose blog-content">
        <slot />
      </article>
      <aside class="blog-sidebar">
        <div class="sidebar-cta">
          <h3>Talk to a Loan Officer</h3>
          <p>Have questions about your mortgage options? We can help you compare programs based on your scenario.</p>
          <a href="/contact-us/" class="btn-primary">Contact Us</a>
          <a href="tel:8888389330" class="sidebar-phone">(888) 838-9330</a>
        </div>
        <div class="sidebar-links">
          <h4>Loan Programs</h4>
          <ul>
            <li><a href="/programs/fha-loans/">FHA Loans</a></li>
            <li><a href="/programs/va-loans/">VA Loans</a></li>
            <li><a href="/programs/conventional-loans/">Conventional Loans</a></li>
            <li><a href="/programs/usda-loans/">USDA Loans</a></li>
            <li><a href="/programs/first-time-homebuyer-loans/">First-Time Homebuyer</a></li>
            <li><a href="/programs/refinance-loans/">Refinance</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>

  <CTASection
    heading="Ready to Explore Your Mortgage Options?"
    subtext="Subject to credit, income, property, program, and lender guidelines."
    ctaText="Apply Now"
    ctaUrl="/loan-officers/"
    secondaryCtaText="Contact Us"
    secondaryCtaUrl="/contact/"
  />
</BaseLayout>

<style>
.blog-hero {
  background: var(--color-off-white);
  padding: var(--space-16) 0 var(--space-10);
  border-bottom: 1px solid var(--color-gray-subtle);
}
.blog-hero h1 {
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  margin: var(--space-4) 0 var(--space-4);
}
.blog-meta {
  display: flex; align-items: center; gap: var(--space-2);
  color: var(--color-gray-mid); font-size: var(--text-sm);
  flex-wrap: wrap;
}
.dot { color: var(--color-gray-subtle); }

.blog-layout {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: var(--space-12);
  align-items: start;
}
@media (max-width: 900px) {
  .blog-layout { grid-template-columns: 1fr; }
  .blog-sidebar { order: -1; }
}

.sidebar-cta {
  background: var(--color-navy);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  margin-bottom: var(--space-6);
}
.sidebar-cta h3 { color: var(--color-white); margin-bottom: var(--space-3); font-size: var(--text-xl); }
.sidebar-cta p { color: oklch(80% 0.02 260); font-size: var(--text-sm); max-width: none; margin-bottom: var(--space-4); }
.sidebar-cta .btn-primary { width: 100%; justify-content: center; margin-bottom: var(--space-3); }
.sidebar-phone {
  display: block; color: var(--color-white);
  text-decoration: none; font-weight: 500;
  font-size: var(--text-sm); text-align: center;
  opacity: 0.8;
}
.sidebar-links h4 { font-size: var(--text-base); margin-bottom: var(--space-3); color: var(--color-navy); }
.sidebar-links ul { list-style: none; }
.sidebar-links li { border-bottom: 1px solid var(--color-gray-subtle); }
.sidebar-links a {
  display: block; padding: var(--space-2) 0;
  color: var(--color-navy); text-decoration: none;
  font-size: var(--text-sm); font-weight: 500;
}
.sidebar-links a:hover { color: var(--color-red); }
</style>
