---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, canonicalUrl, ogImage, schema } = Astro.props;
const canonical = canonicalUrl || new URL(Astro.url.pathname, Astro.site).href;
const ogImg = ogImage || '/og-default.jpg';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImg, Astro.site).href} />
  <meta property="og:site_name" content="American Mortgage Services" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImg, Astro.site).href} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Organization schema on every page -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": "American Mortgage Services",
    "alternateName": "We Get It Closed",
    "url": "https://wegetitclosed.com",
    "telephone": "(888) 838-9330",
    "areaServed": ["Alabama", "Florida", "Georgia", "Louisiana", "Michigan", "Tennessee"],
    "description": "Wholesale mortgage broker serving AL, FL, GA, LA, MI, and TN. FHA, VA, USDA, conventional, jumbo, and specialty loan programs.",
    "sameAs": []
  })} />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
