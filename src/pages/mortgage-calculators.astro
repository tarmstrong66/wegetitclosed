---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import MortgageCalculator from '../components/MortgageCalculator.astro';
---
<BaseLayout
  title="Mortgage Calculators | Payment, DTI, Refinance & DSCR | American Mortgage Services"
  description="Free mortgage calculators from American Mortgage Services. Estimate your monthly payment with taxes and insurance, run a refinance savings analysis, check your DSCR, and more."
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span> <span aria-current="page">Mortgage Calculators</span>
      </nav>
      <h1>Mortgage Calculators</h1>
      <p>Estimate payments, savings, and cash flow ratios. All figures are estimates only — actual loan terms, payments, and eligibility depend on your credit, income, property, and lender guidelines.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="calc-hub">
        <MortgageCalculator />
      </div>

      <div class="other-calcs">
        <h2>More Calculators</h2>
        <div class="other-calcs-grid">
          <a href="/refinance-calculator/" class="other-calc-card">
            <div class="other-calc-icon">&#8635;</div>
            <h3>Refinance Savings Calculator</h3>
            <p>Compare your current payment to a new rate. See monthly savings, total interest saved, and your breakeven timeline.</p>
          </a>
          <a href="/dscr-calculator/" class="other-calc-card">
            <div class="other-calc-icon">&#36;</div>
            <h3>DSCR Cash Flow Calculator</h3>
            <p>Evaluate whether a rental property's income supports a DSCR loan. Includes guidance for ratios below 1.0.</p>
          </a>
          <a href="/2-1-buydown-calculator/" class="other-calc-card">
            <div class="other-calc-icon">&#8595;</div>
            <h3>2-1 Buydown Calculator</h3>
            <p>See how a temporary rate reduction in years one and two affects your payment and total buydown cost.</p>
          </a>
        </div>
      </div>

      <div class="calc-disclaimer">
        <p><strong>Disclaimer:</strong> These calculators are for estimation purposes only and do not account for all costs or lender overlays. Actual loan terms, payments, and eligibility are subject to credit review, income verification, property appraisal, and lender guidelines. These tools do not constitute a loan application or commitment to lend.</p>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Talk Numbers with a Loan Officer?"
    subtext="Get accurate estimates based on your actual scenario, credit, and the property you're considering."
    ctaText="Contact Us"
    ctaUrl="/contact-us/"
    secondaryCtaText="Meet Our Loan Officers"
    secondaryCtaUrl="/loan-officers/"
  />
</BaseLayout>

<style>
.page-hero {
  background: var(--color-navy); color: var(--color-white);
  padding: var(--space-16) 0 var(--space-12);
}
.page-hero h1 { color: var(--color-white); font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl)); margin: var(--space-4) 0 var(--space-4); }
.page-hero p { color: oklch(80% 0.02 260); font-size: var(--text-base); max-width: 60ch; }
.breadcrumb-nav { font-size: var(--text-sm); color: oklch(65% 0.02 260); margin-bottom: var(--space-4); }
.breadcrumb-nav a { color: oklch(70% 0.02 260); text-decoration: none; }
.breadcrumb-nav span { margin: 0 var(--space-2); }

.calc-hub {
  margin-bottom: var(--space-16);
}

.other-calcs {
  margin-bottom: var(--space-10);
}
.other-calcs h2 {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-6);
}
.other-calcs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
@media (max-width: 900px) { .other-calcs-grid { grid-template-columns: 1fr; max-width: 500px; } }

.other-calc-card {
  display: block;
  background: var(--color-white);
  border: 1px solid var(--color-gray-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  text-decoration: none;
  box-shadow: var(--shadow-card);
  transition: box-shadow 150ms, border-color 150ms, transform 150ms;
}
.other-calc-card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--color-navy);
  transform: translateY(-2px);
}
.other-calc-icon {
  font-size: 1.8rem;
  margin-bottom: var(--space-3);
  color: var(--color-navy);
}
.other-calc-card h3 {
  font-size: var(--text-lg);
  color: var(--color-navy);
  margin-bottom: var(--space-2);
}
.other-calc-card p {
  font-size: var(--text-sm);
  color: var(--color-gray-mid);
  max-width: none;
  margin: 0;
  line-height: 1.6;
}

.calc-disclaimer {
  background: var(--color-off-white); border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-6);
  border: 1px solid var(--color-gray-subtle);
}
.calc-disclaimer p { font-size: var(--text-xs); color: var(--color-gray-mid); max-width: none; }
</style>
