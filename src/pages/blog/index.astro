---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout
  title="Mortgage Blog | American Mortgage Services"
  description="Mortgage guides, loan program comparisons, and homebuyer tips from American Mortgage Services. Serving borrowers in AL, FL, GA, LA, MI, and TN."
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span> <span aria-current="page">Blog</span>
      </nav>
      <h1>Mortgage Resources & Guides</h1>
      <p>Practical guidance on mortgage programs, the homebuying process, and refinance decisions from American Mortgage Services.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p>No posts yet. Check back soon.</p>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}/`} class="post-card">
              <div class="post-tags">
                {post.data.tags.slice(0, 2).map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="read-more">Read Article →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <CTASection
    heading="Have Questions About Your Mortgage Options?"
    subtext="Talk with a loan officer about programs available in your state based on your scenario."
    ctaText="Contact Us"
    ctaUrl="/contact/"
    secondaryCtaText="Apply Now"
    secondaryCtaUrl="/loan-officers/"
  />
</BaseLayout>

<style>
.page-hero {
  background: var(--color-navy); color: var(--color-white);
  padding: var(--space-16) 0 var(--space-12);
}
.page-hero h1 { color: var(--color-white); font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl)); margin: var(--space-4) 0 var(--space-4); }
.page-hero p { color: oklch(80% 0.02 260); font-size: var(--text-lg); max-width: 55ch; }
.breadcrumb-nav { font-size: var(--text-sm); color: oklch(65% 0.02 260); margin-bottom: var(--space-4); }
.breadcrumb-nav a { color: oklch(70% 0.02 260); text-decoration: none; }
.breadcrumb-nav span { margin: 0 var(--space-2); }

.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
@media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 580px) { .blog-grid { grid-template-columns: 1fr; } }

.post-card {
  display: flex; flex-direction: column; gap: var(--space-3);
  background: var(--color-white); border-radius: var(--radius-lg);
  padding: var(--space-6); border: 1px solid var(--color-gray-subtle);
  box-shadow: var(--shadow-card); text-decoration: none;
  transition: transform 150ms ease-out, box-shadow 150ms ease-out;
}
.post-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
.post-tags { display: flex; gap: var(--space-2); flex-wrap: wrap; }
.tag {
  font-size: var(--text-xs); font-weight: 600; color: var(--color-red);
  background: oklch(97% 0.01 25); padding: 2px 8px; border-radius: var(--radius-pill);
}
.post-card h2 {
  font-size: var(--text-xl); color: var(--color-navy); margin: 0;
}
.post-card p { font-size: var(--text-sm); color: var(--color-gray-mid); flex: 1; max-width: none; }
.post-meta {
  display: flex; justify-content: space-between; align-items: center;
  font-size: var(--text-xs); color: var(--color-gray-mid); margin-top: auto;
}
.read-more { color: var(--color-red); font-weight: 600; }
</style>
