---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact Us | American Mortgage Services"
  description="Contact American Mortgage Services to talk with a loan officer about your mortgage options in AL, FL, GA, LA, MI, or TN. Call (888) 838-9330 or send us a message."
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span> <span aria-current="page">Contact Us</span>
      </nav>
      <h1>Contact American Mortgage Services</h1>
      <p>Talk with a loan officer about your mortgage scenario. We serve borrowers in AL, FL, GA, LA, MI, and TN.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <div class="contact-form-wrap">
        <h2>Send Us a Message</h2>
        <p class="form-note">Submitting this form does not constitute a loan application or commitment to lend. A loan officer will typically follow up within one business day.</p>

        <form class="contact-form" action="/api/contact" method="POST" novalidate>
          <div class="field-row">
            <div class="field">
              <label for="first-name">First Name <span aria-hidden="true">*</span></label>
              <input type="text" id="first-name" name="first-name" required autocomplete="given-name" />
            </div>
            <div class="field">
              <label for="last-name">Last Name <span aria-hidden="true">*</span></label>
              <input type="text" id="last-name" name="last-name" required autocomplete="family-name" />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="email">Email Address <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
            <div class="field">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="state">State</label>
              <select id="state" name="state">
                <option value="">Select a state</option>
                <option value="AL">Alabama</option>
                <option value="FL">Florida</option>
                <option value="GA">Georgia</option>
                <option value="LA">Louisiana</option>
                <option value="MI">Michigan</option>
                <option value="TN">Tennessee</option>
              </select>
            </div>
            <div class="field">
              <label for="loan-type">Loan Type (Optional)</label>
              <select id="loan-type" name="loan-type">
                <option value="">Select a loan type</option>
                <option value="fha">FHA Loan</option>
                <option value="va">VA Loan</option>
                <option value="conventional">Conventional Loan</option>
                <option value="usda">USDA Loan</option>
                <option value="jumbo">Jumbo Loan</option>
                <option value="refinance">Refinance</option>
                <option value="cash-out">Cash-Out Refinance</option>
                <option value="reverse">Reverse Mortgage</option>
                <option value="investor">Investor / DSCR Loan</option>
                <option value="bank-statement">Bank Statement Loan</option>
                <option value="renovation">Renovation Loan</option>
                <option value="unsure">Not Sure Yet</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us a bit about your scenario..."></textarea>
          </div>

          <button type="submit" class="btn-primary submit-btn">Send Message</button>
          <div id="form-status" class="form-status" role="alert" aria-live="polite"></div>
        </form>
      </div>

      <div class="contact-info">
        <div class="info-card">
          <h3>Call Us</h3>
          <a href="tel:8888389330" class="contact-phone">(888) 838-9330</a>
          <p>Monday through Friday, business hours.</p>
        </div>

        <div class="info-card">
          <h3>States We Serve</h3>
          <ul class="state-links">
            <li><a href="/alabama-mortgage/">Alabama</a></li>
            <li><a href="/florida-mortgage/">Florida</a></li>
            <li><a href="/georgia-mortgage/">Georgia</a></li>
            <li><a href="/louisiana-mortgage/">Louisiana</a></li>
            <li><a href="/michigan-mortgage/">Michigan</a></li>
            <li><a href="/tennessee-mortgage/">Tennessee</a></li>
          </ul>
        </div>

        <div class="info-card info-card-cta">
          <h3>Ready to Apply?</h3>
          <p>If you're ready to move forward, start your application and a loan officer will review your information and contact you.</p>
          <a href="/loan-officers/" class="btn-primary">Start Your Application</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero {
  background: var(--color-navy); color: var(--color-white);
  padding: var(--space-16) 0 var(--space-12);
}
.page-hero h1 { color: var(--color-white); font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl)); margin: var(--space-4) 0 var(--space-4); }
.page-hero p { color: oklch(80% 0.02 260); font-size: var(--text-lg); max-width: 55ch; }
.breadcrumb-nav { font-size: var(--text-sm); color: oklch(65% 0.02 260); margin-bottom: var(--space-4); }
.breadcrumb-nav a { color: oklch(70% 0.02 260); text-decoration: none; }
.breadcrumb-nav span { margin: 0 var(--space-2); }

.contact-layout {
  display: grid; grid-template-columns: 1fr 340px; gap: var(--space-12); align-items: start;
}
@media (max-width: 900px) { .contact-layout { grid-template-columns: 1fr; } }

.contact-form-wrap h2 { font-size: var(--text-3xl); margin-bottom: var(--space-2); }
.form-note { font-size: var(--text-sm); color: var(--color-gray-mid); margin-bottom: var(--space-6); max-width: none; }

.contact-form { display: flex; flex-direction: column; gap: var(--space-4); }
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
@media (max-width: 540px) { .field-row { grid-template-columns: 1fr; } }
.field { display: flex; flex-direction: column; gap: var(--space-1); }
label { font-size: var(--text-sm); font-weight: 600; color: var(--color-navy); }
label span { color: var(--color-red); }
input, select, textarea {
  font-family: var(--font-body); font-size: var(--text-base);
  border: 1.5px solid var(--color-gray-subtle); border-radius: var(--radius-md);
  padding: 10px 14px; background: var(--color-white); color: var(--color-gray-body);
  transition: border-color 150ms ease-out;
  width: 100%;
}
input:focus, select:focus, textarea:focus {
  outline: none; border-color: var(--color-navy);
  box-shadow: 0 0 0 3px oklch(22% 0.06 260 / 0.12);
}
textarea { resize: vertical; min-height: 100px; }
.submit-btn { align-self: flex-start; margin-top: var(--space-2); }

.info-card {
  background: var(--color-off-white); border-radius: var(--radius-lg);
  padding: var(--space-6); margin-bottom: var(--space-4);
}
.info-card h3 { font-size: var(--text-xl); margin-bottom: var(--space-3); }
.contact-phone {
  display: block; font-size: var(--text-2xl); font-weight: 700;
  color: var(--color-navy); text-decoration: none; margin-bottom: var(--space-2);
  font-family: var(--font-display);
}
.contact-phone:hover { color: var(--color-red); }
.info-card p { font-size: var(--text-sm); color: var(--color-gray-mid); max-width: none; }
.state-links { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2); }
.state-links a { color: var(--color-navy); font-weight: 500; font-size: var(--text-sm); text-decoration: none; }
.state-links a:hover { color: var(--color-red); }
.info-card-cta { background: var(--color-navy); }
.info-card-cta h3 { color: var(--color-white); }
.info-card-cta p { color: oklch(75% 0.02 260); margin-bottom: var(--space-4); }
.info-card-cta .btn-primary { width: 100%; justify-content: center; }

.form-status { font-size: var(--text-sm); margin-top: var(--space-3); padding: var(--space-3) var(--space-4); border-radius: var(--radius-md); display: none; }
.form-status--success { display: block; background: oklch(95% 0.05 145); color: oklch(30% 0.1 145); }
.form-status--error { display: block; background: oklch(95% 0.05 25); color: oklch(35% 0.15 25); }
</style>

<script>
const form = document.querySelector('.contact-form') as HTMLFormElement;
const btn = form.querySelector('.submit-btn') as HTMLButtonElement;
const status = document.getElementById('form-status')!;

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  btn.disabled = true;
  btn.textContent = 'Sending...';
  status.textContent = '';
  status.className = 'form-status';

  const data = Object.fromEntries(new FormData(form));

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        firstName: data['first-name'],
        lastName: data['last-name'],
        email: data['email'],
        phone: data['phone'],
        state: data['state'],
        loanType: data['loan-type'],
        message: data['message'],
      }),
    });

    const result = await res.json();

    if (result.success) {
      form.reset();
      status.textContent = 'Your message was sent. A loan officer will follow up within one business day.';
      status.classList.add('form-status--success');
    } else {
      throw new Error('Send failed');
    }
  } catch {
    status.textContent = 'Something went wrong. Please call us at (888) 838-9330 or try again.';
    status.classList.add('form-status--error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Send Message';
  }
});
</script>
