---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTASection from '../../components/CTASection.astro';

import imgAbout    from '../../assets/images/About-American-Mortgage.jpg';
import imgTeam     from '../../assets/images/team-page-photo.jpg';
import imgClay     from '../../assets/images/Clay-Heitler.jpg';
import imgShannon  from '../../assets/images/Shannon-Robinson-1-200x300.jpg';
import imgJoAnne   from '../../assets/images/JoAnne-Patton-200x256.jpg';
import imgLindsey  from '../../assets/images/Lindsey-Randall-200x300.jpg';
import imgMarivel  from '../../assets/images/Marivel-Noyola-200x300.jpg';
import imgAlex     from '../../assets/images/AlexanderRotz-200x300.jpg';

const staff = [
  { name: 'Shannon Robinson', title: 'Operations Manager',       nmls: '',         image: imgShannon },
  { name: 'JoAnne Patton',   title: 'Processor',                nmls: '342684',   image: imgJoAnne  },
  { name: 'Lindsey Randall', title: 'Processor',                nmls: '',         image: imgLindsey },
  { name: 'Marivel Noyola',  title: 'Administrator',            nmls: '',         image: imgMarivel },
  { name: 'Alexander Rotz',  title: 'Loan Partner',             nmls: '1555722',  image: imgAlex    },
];
---
<BaseLayout
  title="Our Team | American Mortgage Services — We Get It Closed"
  description="Meet the leadership and support team behind American Mortgage Services. Based in Tampa, FL and serving borrowers across AL, FL, GA, LA, MI, and TN since 1999."
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <span aria-current="page">The Team</span>
      </nav>
      <h1>The Team Behind We Get It Closed</h1>
      <p>American Mortgage Services has been helping borrowers close since 1999. Here's the leadership and staff that make it happen.</p>
    </div>
  </section>

  <TrustBar />

  <section class="section">
    <div class="container">

      <!-- Company photos -->
      <div class="company-photos">
        <div class="photo-square">
          <Image
            src={imgAbout}
            alt="American Mortgage Services team group photo"
            width={600}
            height={600}
            format="webp"
            quality={85}
            class="company-photo"
          />
        </div>
        <div class="photo-wide">
          <Image
            src={imgTeam}
            alt="American Mortgage Services staff celebrating Boss Day"
            width={900}
            height={506}
            format="webp"
            quality={85}
            class="company-photo"
          />
        </div>
      </div>

      <!-- About copy -->
      <div class="about-copy">
        <h2>A Few Words About The Company</h2>
        <p>American Mortgage Services is an independent mortgage broker, offering more loan programs with fewer restrictions than banks and credit unions. We rarely charge lender fees on FHA, VA, USDA, and Conventional loans. We specialize in renovation loans such as the FHA 203K and the Fannie Mae Homestyle.</p>
        <p>We close the loans that other lenders cannot, and we close the majority of our loans in less than 30 days. We pride ourselves in closing loans on time and keeping our realtors and buyers updated and well-informed throughout the closing process. We do not operate by banker's hours; we are here to answer our clients' calls and questions 24/7. We don't just get your loan approved, we get it closed!</p>
      </div>

      <!-- Clay featured card -->
      <div class="clay-card">
        <div class="clay-photo-wrap">
          <Image
            src={imgClay}
            alt="Clayton Heitler, Owner and Founder of American Mortgage Services"
            width={260}
            height={320}
            format="webp"
            quality={85}
            class="clay-photo"
          />
        </div>
        <div class="clay-bio">
          <p class="clay-name">Clayton Heitler</p>
          <p class="clay-role">Owner &amp; Founder</p>
          <p class="clay-nmls">NMLS# 372592</p>
          <p>Clay Heitler (NMLS #372592) is the President and Founder of American Mortgage Services, Inc. Clay has owned and operated Tampa-based Affordable Home Mortgage (now American Mortgage Services) since 1999.</p>
          <p>Clay was born and raised in Baton Rouge, LA, and relocated to Florida in the early 90's. He graduated from the University of South Florida in 1993 and is still an avid Bulls fan. Clay is an active member of the Tampa Bay community and is the friendliest person you will ever meet!</p>
          <div class="clay-actions">
            <a href="tel:8137895660" class="clay-phone">813.789.9660</a>
            <a href="/loan-officers/" class="btn-primary clay-btn">Apply With Clay</a>
          </div>
        </div>
      </div>

      <!-- Support staff grid -->
      <h2 class="staff-heading">Our Support Team</h2>
      <div class="staff-grid">
        {staff.map(member => (
          <div class="staff-tile">
            <div class="tile-photo-wrap">
              <Image
                src={member.image}
                alt={`${member.name}, ${member.title} at American Mortgage Services`}
                width={400}
                height={440}
                format="webp"
                quality={85}
                class="tile-photo"
              />
            </div>
            <div class="tile-info">
              <p class="tile-name">{member.name}</p>
              <p class="tile-title">{member.title}{member.nmls ? ` / NMLS #${member.nmls}` : ''}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <CTASection
    heading="Ready to Work With Our Team?"
    subtext="Choose a loan officer and start your application — or contact us and we'll help match you with the right person for your scenario."
    ctaText="Meet Our Loan Officers"
    ctaUrl="/loan-officers/"
    secondaryCtaText="Contact Us"
    secondaryCtaUrl="/contact-us/"
  />
</BaseLayout>

<style>
.page-hero {
  background: var(--color-navy); color: var(--color-white);
  padding: var(--space-16) 0 var(--space-12);
}
.page-hero h1 {
  color: var(--color-white);
  font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
  margin: var(--space-4) 0 var(--space-4);
}
.page-hero p { color: oklch(80% 0.02 260); font-size: var(--text-lg); max-width: 60ch; }

.breadcrumb-nav {
  font-size: var(--text-sm); color: oklch(65% 0.02 260); margin-bottom: var(--space-4);
}
.breadcrumb-nav a { color: oklch(70% 0.02 260); text-decoration: none; }
.breadcrumb-nav a:hover { color: var(--color-white); }
.breadcrumb-nav span { margin: 0 var(--space-2); }

/* Company photos */
.company-photos {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: var(--space-4);
  align-items: stretch;
  margin-bottom: var(--space-12);
}
@media (max-width: 640px) {
  .company-photos { grid-template-columns: 1fr; }
}

.photo-square {
  aspect-ratio: 1 / 1;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.photo-wide {
  aspect-ratio: 16 / 9;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.company-photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
}

/* About copy */
.about-copy {
  max-width: 80ch;
  margin-bottom: var(--space-12);
}
.about-copy h2 {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  color: var(--color-navy);
  margin-bottom: var(--space-4);
}
.about-copy p {
  color: var(--color-gray-mid);
  font-size: var(--text-base);
  line-height: 1.7;
  margin-bottom: var(--space-4);
}

/* Clay featured card */
.clay-card {
  display: flex;
  gap: var(--space-8);
  align-items: flex-start;
  background: var(--color-white);
  border: 1px solid var(--color-gray-subtle);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: var(--space-8);
  margin-bottom: var(--space-14);
}
@media (max-width: 640px) {
  .clay-card { flex-direction: column; align-items: center; text-align: center; }
  .clay-actions { justify-content: center; }
}

.clay-photo-wrap {
  flex-shrink: 0;
  width: 260px;
  height: 320px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 3px solid oklch(87% 0.05 255);
}
.clay-photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  display: block;
}

.clay-bio { flex: 1; }
.clay-name {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--color-red);
  margin: 0 0 var(--space-1);
  max-width: none;
}
.clay-role {
  font-size: var(--text-base);
  color: var(--color-blue);
  font-weight: 700;
  margin: 0 0 var(--space-1);
  max-width: none;
}
.clay-nmls {
  font-size: var(--text-xs);
  color: oklch(55% 0.01 260);
  margin: 0 0 var(--space-5);
  max-width: none;
}
.clay-bio p {
  color: var(--color-gray-mid);
  line-height: 1.7;
  margin: 0 0 var(--space-4);
  max-width: none;
}
.clay-actions {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
  margin-top: var(--space-2);
}
.clay-phone {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-red);
  text-decoration: none;
}
.clay-phone:hover { color: var(--color-navy); }
.clay-btn { font-size: var(--text-sm); }

/* Staff grid */
.staff-heading {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  color: var(--color-navy);
  margin-bottom: var(--space-8);
}

.staff-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
}
@media (max-width: 768px) { .staff-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .staff-grid { grid-template-columns: 1fr; } }

.staff-tile {
  background: var(--color-white);
  border: 1px solid var(--color-gray-subtle);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: transform 150ms ease-out, box-shadow 150ms ease-out;
}
.staff-tile:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}

.tile-photo-wrap {
  width: 100%;
  height: 220px;
  overflow: hidden;
}
.tile-photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  display: block;
}

.tile-info {
  padding: var(--space-4) var(--space-5);
  text-align: center;
}
.tile-name {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-navy);
  margin: 0 0 var(--space-1);
  max-width: none;
}
.tile-title {
  font-size: var(--text-xs);
  color: var(--color-blue);
  font-weight: 600;
  margin: 0;
  max-width: none;
}
</style>
