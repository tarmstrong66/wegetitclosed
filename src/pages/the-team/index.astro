---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTASection from '../../components/CTASection.astro';

import imgAbout   from '../../assets/images/About-American-Mortgage.jpg';
import imgTeam    from '../../assets/images/team-page-photo.jpg';
import imgClay    from '../../assets/images/Clay-Heitler.jpg';
import imgShannon from '../../assets/images/Shannon-Robinson-1-200x300.jpg';
import imgJoAnne  from '../../assets/images/JoAnne-Patton-200x256.jpg';
import imgLindsey from '../../assets/images/Lindsey-Randall-200x300.jpg';
import imgMarivel from '../../assets/images/Marivel-Noyola-200x300.jpg';
import imgAlex    from '../../assets/images/AlexanderRotz-200x300.jpg';

const staff = [
  {
    name: 'Shannon Robinson',
    title: 'Operations Manager',
    nmls: '',
    image: imgShannon,
    bio: 'Shannon is a returning employee that moved back to Tampa in the beginning of 2021. She brings 15 years of management experience to the team and loves her job! Shannon holds a degree in Business Administration, Summa Cum Laude, and currently lives in north Tampa with her husband and two children.',
  },
  {
    name: 'JoAnne Patton',
    title: 'Processor',
    nmls: '342684',
    image: imgJoAnne,
    bio: 'JoAnne has been serving mortgage needs in the Tampa Bay area for the past 30 years. With her knowledge and experience, she is committed to providing excellent service from application to closing. In her free time, she loves spending time with her husband and two boys, RV\'ing and playing tennis.',
  },
  {
    name: 'Lindsey Randall',
    title: 'Processor',
    nmls: '',
    image: imgLindsey,
    bio: 'Lindsey has been serving as a Loan Processor since March 2021, processing loans right out of college in 2003 before rejoining the AMS team. She has a background in finance and working closely with Real Estate Agents. Lindsey graduated from the University of Mississippi in Finance and Management. Outside of processing, she loves God, helping others, and delicious food.',
  },
  {
    name: 'Marivel Noyola',
    title: 'Administrator',
    nmls: '',
    image: imgMarivel,
    bio: 'Marivel rejoined the mortgage industry - where she started in 2000 - after spending time raising her family and helping with the family trucking business in Houston, Texas. In 2019 she relocated to Tampa, Florida. Marivel is excited to be a part of the American Mortgage Services family. In her free time she loves going to the beach and Salsa dancing!',
  },
  {
    name: 'Alexander Rotz',
    title: 'Loan Partner',
    nmls: '1555722',
    image: imgAlex,
    bio: 'Alex is a dedicated mortgage professional with a proven track record of success helping clients achieve their homeownership dreams. With 10 years of experience, he excels at tailoring mortgage solutions to individual needs and building long-term relationships with clients and industry partners. A Tampa native, Alex enjoys boating, fishing, or any activity on the water!',
  },
];
---
<BaseLayout
  title="Our Team | American Mortgage Services - We Get It Closed"
  description="Meet the leadership and support team behind American Mortgage Services. Based in Tampa, FL and serving borrowers across AL, FL, GA, LA, MI, and TN since 1999."
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <span aria-current="page">The Team</span>
      </nav>
      <h1>The Team Behind We Get It Closed</h1>
      <p>American Mortgage Services has been helping borrowers close since 1999. Here's the leadership and staff that make it happen.</p>
    </div>
  </section>

  <TrustBar />

  <section class="section">
    <div class="container">

      <!-- Company photos -->
      <div class="company-photos">
        <div class="photo-col">
          <Image
            src={imgAbout}
            alt="American Mortgage Services team group photo"
            width={600}
            height={600}
            format="webp"
            quality={85}
            class="company-photo"
          />
        </div>
        <div class="photo-col">
          <Image
            src={imgTeam}
            alt="American Mortgage Services staff celebrating Boss Day"
            width={900}
            height={600}
            format="webp"
            quality={85}
            class="company-photo"
          />
        </div>
      </div>

      <!-- About copy -->
      <div class="about-copy">
        <h2>A Few Words About The Company</h2>
        <p>American Mortgage Services is an independent mortgage broker, offering more loan programs with fewer restrictions than banks and credit unions. We rarely charge lender fees on FHA, VA, USDA, and Conventional loans. We specialize in renovation loans such as the FHA 203K and the Fannie Mae Homestyle.</p>
        <p>We close the loans that other lenders cannot, and we close the majority of our loans in less than 30 days. We pride ourselves in closing loans on time and keeping our realtors and buyers updated and well-informed throughout the closing process. We do not operate by banker's hours; we are here to answer our clients' calls and questions 24/7. We don't just get your loan approved, we get it closed!</p>
      </div>

      <!-- Clay featured card -->
      <div class="member-card clay-card">
        <div class="member-photo-wrap">
          <Image
            src={imgClay}
            alt="Clayton Heitler, Owner and Founder of American Mortgage Services"
            width={220}
            height={280}
            format="webp"
            quality={85}
            class="member-photo"
          />
        </div>
        <div class="member-bio">
          <p class="member-name clay-name">Clayton Heitler</p>
          <p class="member-role">Owner &amp; Founder</p>
          <p class="member-nmls">NMLS# 372592</p>
          <p>Clay Heitler (NMLS #372592) is the President and Founder of American Mortgage Services, Inc. Clay has owned and operated Tampa-based Affordable Home Mortgage (now American Mortgage Services) since 1999.</p>
          <p>Clay was born and raised in Baton Rouge, LA, and relocated to Florida in the early 90's. He graduated from the University of South Florida in 1993 and is still an avid Bulls fan. Clay is an active member of the Tampa Bay community and is the friendliest person you will ever meet!</p>
          <div class="clay-actions">
            <a href="tel:8137899660" class="clay-phone">813.789.9660</a>
            <a href="/apply-now/" class="btn-primary clay-btn">Apply With Clay</a>
          </div>
        </div>
      </div>

      <!-- Support staff -->
      <h2 class="staff-heading">Our Support Team</h2>
      <div class="staff-grid">
        {staff.map(member => (
          <div class="member-card">
            <div class="member-photo-wrap">
              <Image
                src={member.image}
                alt={`${member.name}, ${member.title} at American Mortgage Services`}
                width={180}
                height={240}
                format="webp"
                quality={85}
                class="member-photo"
              />
            </div>
            <div class="member-bio">
              <p class="member-name">{member.name}</p>
              <p class="member-role">
                {member.title}
                {member.nmls && <span class="member-nmls-inline"> / NMLS #{member.nmls}</span>}
              </p>
              <p class="member-body">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <CTASection
    heading="Ready to Work With Our Team?"
    subtext="Choose a loan officer and start your application - or contact us and we'll help match you with the right person for your scenario."
    ctaText="Meet Our Loan Officers"
    ctaUrl="/loan-officers/"
    secondaryCtaText="Contact Us"
    secondaryCtaUrl="/contact-us/"
  />
</BaseLayout>

<style>
/* Hero */
.page-hero {
  background: var(--color-navy);
  color: var(--color-white);
  padding: var(--space-16) 0 var(--space-12);
}
.page-hero h1 {
  color: var(--color-white);
  font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
  margin: var(--space-4) 0 var(--space-4);
}
.page-hero p {
  color: oklch(80% 0.02 260);
  font-size: var(--text-lg);
  max-width: 60ch;
}

.breadcrumb-nav {
  font-size: var(--text-sm);
  color: oklch(65% 0.02 260);
  margin-bottom: var(--space-4);
}
.breadcrumb-nav a { color: oklch(70% 0.02 260); text-decoration: none; }
.breadcrumb-nav a:hover { color: var(--color-white); }
.breadcrumb-nav span { margin: 0 var(--space-2); }

/* Company photos - left narrower (square group), right wider (landscape) */
.company-photos {
  display: grid;
  grid-template-columns: 5fr 9fr;
  gap: var(--space-4);
  align-items: start;
  margin-bottom: var(--space-12);
}
@media (max-width: 640px) {
  .company-photos { grid-template-columns: 1fr; }
}

.photo-col {
  border-radius: var(--radius-lg);
  overflow: hidden;
  line-height: 0;
}
.company-photo {
  width: 100%;
  height: auto;
  display: block;
}

/* About copy */
.about-copy {
  max-width: 80ch;
  margin: 0 auto var(--space-12);
  text-align: center;
}
.about-copy h2 {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  color: var(--color-navy);
  margin-bottom: var(--space-4);
}
.about-copy p {
  color: var(--color-gray-mid);
  font-size: var(--text-base);
  line-height: 1.7;
  margin-bottom: var(--space-4);
}

/* Shared member card - horizontal photo + bio */
.member-card {
  display: flex;
  gap: var(--space-6);
  align-items: flex-start;
  background: var(--color-white);
  border: 1px solid var(--color-gray-subtle);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: var(--space-6);
  margin-bottom: var(--space-6);
}
@media (max-width: 560px) {
  .member-card {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .clay-actions { justify-content: center; }
}

/* Photo wrap - portrait, no fixed height crop */
.member-photo-wrap {
  flex-shrink: 0;
  width: 180px;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 2px solid oklch(90% 0.03 255);
  line-height: 0;
}

/* Clay gets a slightly larger photo */
.clay-card .member-photo-wrap {
  width: 220px;
}

.member-photo {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  object-position: center top;
}

/* Bio text */
.member-bio { flex: 1; }

.member-name {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-navy);
  margin: 0 0 var(--space-1);
  max-width: none;
}
.clay-name {
  font-size: var(--text-2xl);
  color: var(--color-red);
}

.member-role {
  font-size: var(--text-sm);
  color: var(--color-blue);
  font-weight: 600;
  margin: 0 0 var(--space-4);
  max-width: none;
}
.member-nmls {
  font-size: var(--text-xs);
  color: oklch(55% 0.01 260);
  font-weight: 400;
  margin: 0 0 var(--space-5);
  max-width: none;
  display: block;
}
.member-nmls-inline {
  font-weight: 400;
  color: oklch(55% 0.01 260);
  font-size: var(--text-xs);
}

.member-bio p {
  color: var(--color-gray-mid);
  line-height: 1.7;
  margin: 0 0 var(--space-4);
  max-width: none;
}
.member-bio p:last-child { margin-bottom: 0; }

.member-body {
  color: var(--color-gray-mid);
  font-size: var(--text-sm);
  line-height: 1.75;
  margin: 0;
  max-width: none;
}

/* Clay CTA row */
.clay-actions {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
  margin-top: var(--space-4);
}
.clay-phone {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-red);
  text-decoration: none;
}
.clay-phone:hover { color: var(--color-navy); }
.clay-btn { font-size: var(--text-sm); }

/* Support staff section - two-column card grid */
.staff-heading {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  color: var(--color-navy);
  margin-bottom: var(--space-6);
}

.staff-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5);
}
@media (max-width: 768px) {
  .staff-grid { grid-template-columns: 1fr; }
}

/* Cards inside the grid reset bottom margin (grid gap handles it) */
.staff-grid .member-card { margin-bottom: 0; }
</style>
