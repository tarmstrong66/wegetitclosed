---
---

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="redGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:oklch(52% 0.22 25);stop-opacity:1" />
      <stop offset="100%" style="stop-color:oklch(46% 0.22 25);stop-opacity:1" />
    </linearGradient>
  </defs>
</svg>

<div class="programs-wrapper">
  <div class="container">

    <!-- PURCHASE -->
    <section class="program-section" id="purchase">
      <h2 class="section-heading">Buy a Home</h2>
      <p class="section-sub">Whether you're a first-time buyer or moving up, these programs cover every purchase scenario across AL, FL, GA, LA, MI, and TN.</p>
      <a href="/loan-officers/" class="start-app-btn">Start Your Application</a>
      <div class="program-grid">

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Buy with 3% Down</h3>
            <p class="card-desc">Conventional loans for buyers with strong credit. We shop 40+ wholesale lenders to find rates retail banks can't match.</p>
          </div>
          <a href="/programs/conventional-loans/" class="card-link">Conventional Loan Options &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4,10H8V21H4V10M10,10H14V21H10V10M16,10H20V21H16V10M12,1L2,6V8H22V6L12,1Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Buy with 3.5% Down</h3>
            <p class="card-desc">FHA loans are a strong path for first-time buyers. Low down payments and flexible credit guidelines.</p>
          </div>
          <a href="/programs/fha-loans/" class="card-link">FHA Loan Requirements &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12,15.39L8.24,17.66L9.23,13.38L5.91,10.5L10.29,10.13L12,6.09L13.71,10.13L18.09,10.5L14.77,13.38L15.76,17.66L12,15.39M22,9.24L14.81,8.63L12,2L9.19,8.63L2,9.24L7.45,13.97L5.82,21L12,17.27L18.18,21L16.54,13.97L22,9.24Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">$0 Down for Veterans</h3>
            <p class="card-desc">VA loans with elite $0 down financing and specialized military underwriting for eligible veterans and active duty service members.</p>
          </div>
          <a href="/programs/va-loans/" class="card-link">VA Loan Benefits &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12,21L15.6,11L12,2L8.4,11L12,21M13,22H11V23H13V22M15,13L21.5,10.5L18.5,4L12.5,10L15,13M11.5,10L5.5,4L2.5,10.5L9,13L11.5,10Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">$0 Down, Rural Properties</h3>
            <p class="card-desc">USDA loans for eligible rural and suburban properties. We help buyers identify eligible areas and navigate the approval process.</p>
          </div>
          <a href="/programs/usda-loans/" class="card-link">Check USDA Eligibility &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M15,14V11H18V9H15V6H13V9H10V7H8V9H5V11H8V14H5V16H8V19H10V16H13V19H15V16H18V14H15M13,14H10V11H13V14Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Buying a High-Value Property?</h3>
            <p class="card-desc">Jumbo loans up to $3M+ with no PMI required. The preferred path for buyers financing luxury and high-value homes.</p>
          </div>
          <a href="/programs/jumbo-loans/" class="card-link">Jumbo Loan Requirements &rarr;</a>
        </div>

      </div>
    </section>

    <div class="spacer"></div>

    <!-- ZERO DOWN -->
    <section class="program-section" id="zero-down">
      <h2 class="section-heading">Zero Down &amp; First-Time Buyers</h2>
      <p class="section-sub">No down payment? No problem. These programs are built for first-time buyers and qualifying borrowers across our 6-state footprint.</p>
      <a href="/loan-officers/" class="start-app-btn">Start Your Application</a>
      <div class="program-grid">

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12,3L2,12H5V20H10V14H14V20H19V12H22L12,3M12,8.5A1.5,1.5 0 0,1 13.5,10A1.5,1.5 0 0,1 12,11.5A1.5,1.5 0 0,1 10.5,10A1.5,1.5 0 0,1 12,8.5Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">First-Time Homebuyer Programs</h3>
            <p class="card-desc">State-backed programs and down payment assistance grants for first-time buyers relocating or buying for the first time.</p>
          </div>
          <a href="/programs/first-time-homebuyer-loans/" class="card-link">First-Time Buyer Programs &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Keep Your Cash, Still Buy</h3>
            <p class="card-desc">Programs requiring as little as 0% down. Keep your liquid cash for moving costs, furnishings, or an emergency fund.</p>
          </div>
          <a href="/programs/fha-loans/" class="card-link">Compare Down Payment Programs &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,7V13L15.25,15.58L16,14.33L12.5,12.25V7H11Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Low Credit Score Options</h3>
            <p class="card-desc">Credit challenges don't have to end your homebuying journey. We have programs for scores as low as 500 with the right documentation.</p>
          </div>
          <a href="/programs/low-credit-score-mortgage-options/" class="card-link">Low Credit Programs &rarr;</a>
        </div>

      </div>
    </section>

    <div class="spacer"></div>

    <!-- INVESTMENT -->
    <section class="program-section" id="investment">
      <h2 class="section-heading">Investment &amp; Non-QM Mortgages</h2>
      <p class="section-sub">Qualify on cash flow, deposits, or asset-based income rather than tax returns alone. Great for investors and self-employed borrowers.</p>
      <a href="/loan-officers/" class="start-app-btn">Start Your Application</a>
      <div class="program-grid">

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M15,11V5L12,2L9,5V7H3V21H21V11H15M7,19H5V17H7V19M7,15H5V13H7V15M7,11H5V9H7V11M13,19H11V17H13V19M13,15H11V13H13V15M13,11H11V9H13V11M13,7H11V5H13V7M19,19H17V17H19V19M19,15H17V13H19V15"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Build Your Rental Portfolio</h3>
            <p class="card-desc">Portfolio-building loans for investors. We help landlords maximize ROI in short-term and long-term rental markets across 6 states.</p>
          </div>
          <a href="/programs/investor-loans/" class="card-link">Investor Loan Options &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M16,6L18.29,8.29L13.41,13.17L9.41,9.17L2,16.59L3.41,18L9.41,12L13.41,16L19.71,9.71L22,12V6H16Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Qualify on Cash Flow, Not Income</h3>
            <p class="card-desc">DSCR loans qualify on the property's rental income, not your personal tax returns. Ideal for vacation rentals and investment properties.</p>
          </div>
          <a href="/programs/investor-loans/" class="card-link">DSCR Qualifier &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20C4,21.11 4.89,22 6,22H18C19.11,22 20,21.11 20,20V8L14,2H6M11,15V12H12V15H13V16H12V19H11V16H10V15H11Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Self-Employed? Use Your Deposits</h3>
            <p class="card-desc">Qualify using 12â€“24 months of bank deposits instead of tax returns. The ultimate tool for entrepreneurs and small business owners.</p>
          </div>
          <a href="/programs/bank-statement-loans/" class="card-link">Bank Statement Loan Guide &rarr;</a>
        </div>

      </div>
    </section>

    <!-- ADVANTAGE BOX -->
    <div class="advantage-box">
      <h4 class="advantage-heading">The We Get It Closed Advantage</h4>
      <p>As wholesale mortgage brokers, we access rates retail banks can't match. We do it across 6 states with a team that's closed thousands of loans. No lender fees on FHA, VA, and USDA loans.</p>
    </div>

    <!-- REFINANCE -->
    <section class="program-section" id="refinance">
      <h2 class="section-heading">Refinance &amp; Equity</h2>
      <p class="section-sub">Already own a home in one of our 6 states? Lower your rate, tap your equity, or finance a renovation. We shop 40+ lenders to find your best option.</p>
      <a href="/loan-officers/" class="start-app-btn">Start Your Application</a>
      <div class="program-grid">

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M19,8L15,12H18A6,6 0 0,1 12,18C9.5,18 7.29,16.5 6.37,14.23L4.91,15.69C6.38,18.79 9.5,21 13,21A8,8 0 0,0 21,13H24L20,9L19,8M5,9C5.83,6.8 8.1,5.2 11,5.04V8L15,4L11,0V3C6.58,3.2 3,6.9 3,11.5C3,12.19 3.09,12.86 3.25,13.5L5.27,11.5C5.09,10.87 5,10.2 5,9.5C5,9.33 5,9.16 5,9Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Lower Your Mortgage Payment</h3>
            <p class="card-desc">Rate reduction, term change, or move to a fixed-rate mortgage. We shop 40+ wholesale lenders to find your best refinance option.</p>
          </div>
          <a href="/programs/refinance-loans/" class="card-link">Rate Drop Analysis &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M14,6H10V4H14M14,14H10V12H14M14,2H10A2,2 0 0,0 8,4V20A2,2 0 0,0 10,22H14A2,2 0 0,0 16,20V4A2,2 0 0,0 14,2Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Tap the Equity in Your Home</h3>
            <p class="card-desc">Cash-out refinance to access your home's equity for debt consolidation, home improvements, or major life expenses.</p>
          </div>
          <a href="/programs/cash-out-refinance/" class="card-link">Equity Access Options &rarr;</a>
        </div>

        <div class="program-card">
          <div class="icon-box">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L9,6L6,9L1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1C4.8,14 7.5,14.5 9.8,13.6L18.9,22.7C19.3,23.1 19.9,23.1 20.3,22.7L22.6,20.4C23.1,20 23.1,19.3 22.7,19Z"/></svg>
          </div>
          <div class="card-body">
            <h3 class="card-title">Renovation Financing</h3>
            <p class="card-desc">Buy and finance repairs in one loan, or finance renovations on your existing home. FHA 203k and conventional renovation options available.</p>
          </div>
          <a href="/programs/renovation-loans/" class="card-link">Renovation Loan Guide &rarr;</a>
        </div>

      </div>
    </section>

  </div>
</div>

<style>
.programs-wrapper {
  background: var(--color-white);
  padding: var(--space-8) 0 var(--space-16);
}

.program-section {
  padding: var(--space-6) 0 0;
}

.section-heading {
  font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
  font-weight: 700;
  color: var(--color-navy);
  border-left: 5px solid var(--color-red);
  padding-left: var(--space-4);
  margin-bottom: var(--space-4);
  line-height: 1.2;
  font-family: var(--font-display);
}

.section-sub {
  font-size: var(--text-lg);
  color: var(--color-gray-mid);
  margin-bottom: var(--space-6);
  max-width: 900px;
}

.start-app-btn {
  display: inline-block;
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-gray-mid);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  text-decoration: none;
  padding: 8px 16px;
  background: var(--color-gray-subtle);
  border: 1px solid #e2e8f0;
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-8);
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.start-app-btn:hover {
  background: var(--color-red);
  color: var(--color-white);
  border-color: var(--color-red);
}

.program-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
  margin-bottom: var(--space-8);
}
@media (min-width: 650px) {
  .program-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .program-grid { grid-template-columns: repeat(3, 1fr); }
}

.program-card {
  background: var(--color-white);
  padding: var(--space-8) var(--space-6);
  border: 1px solid #e2e8f0;
  border-bottom: 4px solid var(--color-red);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.program-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px oklch(22% 0.06 260 / 0.08);
}

.icon-box {
  width: 65px;
  height: 65px;
  margin-bottom: var(--space-6);
  border-radius: 14px;
  background: linear-gradient(145deg, #ffffff, #f1f5f9);
  box-shadow: 4px 4px 10px #e2e8f0, -4px -4px 10px #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.card-icon {
  width: 32px;
  height: 32px;
  fill: url(#redGradient);
}

.card-body { flex: 1; }

.card-title {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: var(--space-3);
  line-height: 1.2;
  font-family: var(--font-body);
}

.card-desc {
  font-size: var(--text-base);
  color: #475569;
  line-height: 1.7;
  max-width: none;
  margin-bottom: 0;
}

.card-link {
  color: var(--color-navy);
  font-weight: 700;
  text-decoration: none;
  text-transform: uppercase;
  font-size: var(--text-xs);
  letter-spacing: 0.08em;
  border-bottom: 2px solid var(--color-red);
  padding-bottom: 4px;
  align-self: flex-start;
  margin-top: var(--space-5);
  transition: color 0.2s;
}
.card-link:hover { color: var(--color-red); }

.advantage-box {
  background: var(--color-navy);
  border-top: 5px solid var(--color-red);
  padding: var(--space-12) var(--space-10);
  border-radius: 16px;
  margin: var(--space-16) 0;
  text-align: center;
}
.advantage-heading {
  color: var(--color-red);
  font-family: var(--font-body);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 800;
  font-size: var(--text-sm);
  margin-bottom: var(--space-4);
}
.advantage-box p {
  color: var(--color-white);
  font-size: var(--text-lg);
  max-width: 72ch;
  margin: 0 auto;
}

.spacer { height: 60px; }
@media (max-width: 768px) { .spacer { height: 40px; } }
</style>
