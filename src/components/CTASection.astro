---
interface Props {
  heading: string;
  subtext: string;
  ctaText: string;
  ctaUrl: string;
  secondaryCtaText?: string;
  secondaryCtaUrl?: string;
}
const { heading, subtext, ctaText, ctaUrl, secondaryCtaText, secondaryCtaUrl } = Astro.props;
---
<section class="cta-section" role="region" aria-label="Get a mortgage quote">
  <div class="cta-inner">
    <h2>{heading}</h2>
    <p>{subtext}</p>
    <div class="cta-buttons">
      <a href={ctaUrl} class="btn-primary">{ctaText}</a>
      {secondaryCtaText && secondaryCtaUrl && (
        <a href={secondaryCtaUrl} class="btn-primary">{secondaryCtaText}</a>
      )}
      <a href="tel:8888389330" class="btn-primary">Call (888) 838-9330</a>
    </div>
    <p class="cta-nmls">American Mortgage Services &mdash; Licensed Mortgage Broker in AL, FL, GA, LA, MI &amp; TN &mdash; Equal Housing Lender</p>
  </div>
</section>

<style>
.cta-section {
  background-image:
    linear-gradient(oklch(22% 0.06 260 / 0.97), oklch(22% 0.06 260 / 0.94)),
    url('/images/we-get-it-closed-hero-bg.webp');
  background-size: cover;
  background-position: center;
  padding: var(--space-24) var(--space-6);
  text-align: center;
}
.cta-inner {
  max-width: 900px;
  margin: 0 auto;
}
.cta-inner h2 {
  color: var(--color-white);
  font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
  margin-bottom: var(--space-4);
}
.cta-inner > p:not(.cta-nmls) {
  color: oklch(80% 0.02 260);
  font-size: var(--text-xl);
  max-width: 800px;
  margin: 0 auto var(--space-10);
}
.cta-buttons {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-6);
}
@media (min-width: 640px) {
  .cta-buttons { flex-direction: row; flex-wrap: wrap; }
}
.btn-cta-outline {
  display: inline-flex;
  align-items: center;
  background: transparent;
  color: var(--color-white);
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 600;
  padding: 13px 27px;
  border-radius: var(--radius-md);
  border: 2px solid var(--color-white);
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
  white-space: nowrap;
}
.btn-cta-outline:hover {
  background: var(--color-white);
  color: var(--color-navy);
}
.cta-phone {
  display: block;
  color: oklch(65% 0.15 25);
  text-decoration: none;
  font-size: var(--text-xl);
  font-weight: 700;
  margin-bottom: var(--space-6);
  transition: color 0.15s;
}
.cta-phone:hover { color: var(--color-white); }
.cta-nmls {
  font-size: var(--text-xs);
  color: oklch(50% 0.01 260);
  max-width: none;
  margin: 0 auto;
}
</style>
