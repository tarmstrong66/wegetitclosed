<style>
.site-footer {
  background: var(--color-navy);
  color: oklch(80% 0.02 260);
  margin-top: auto;
}
.footer-main {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1.2fr 1.2fr;
  gap: var(--space-10);
  padding: var(--space-16) var(--space-6);
}
@media (max-width: 900px) {
  .footer-main { grid-template-columns: 1fr 1fr; gap: var(--space-8); padding: var(--space-10) var(--space-6); }
}
@media (max-width: 540px) {
  .footer-main { grid-template-columns: 1fr; }
}

.footer-logo {
  font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700;
  color: var(--color-white); margin-bottom: var(--space-1);
}
.footer-tagline { font-size: var(--text-sm); color: var(--color-gold); margin-bottom: var(--space-4); max-width: none; }
.footer-desc { font-size: var(--text-sm); line-height: 1.6; margin-bottom: var(--space-4); max-width: none; }
.footer-phone {
  display: inline-block; color: var(--color-white);
  font-size: var(--text-lg); font-weight: 600; text-decoration: none;
}
.footer-phone:hover { color: var(--color-gold); }

.footer-col h3 {
  font-family: var(--font-body); font-size: var(--text-xs);
  font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--color-gold); margin-bottom: var(--space-4);
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
.footer-col a {
  color: oklch(75% 0.02 260); text-decoration: none;
  font-size: var(--text-sm); transition: color 150ms ease-out;
}
.footer-col a:hover { color: var(--color-white); }
.footer-sub-label {
  font-size: var(--text-xs); font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.06em; color: oklch(55% 0.01 260);
  margin-top: var(--space-2); list-style: none;
}
.footer-sub a {
  padding-left: var(--space-3);
  font-size: var(--text-xs) !important;
}
.footer-compliance {
  font-size: var(--text-xs); line-height: 1.5; margin-top: var(--space-6);
  color: oklch(55% 0.01 260); max-width: none;
}

.footer-bottom {
  border-top: 1px solid var(--color-navy-light);
  padding: var(--space-4) var(--space-6);
}
.footer-bottom-inner {
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: var(--space-2);
}
.footer-bottom p { font-size: var(--text-xs); color: oklch(55% 0.01 260); max-width: none; }
.footer-eho { display: flex; align-items: center; gap: var(--space-2); }
</style>
