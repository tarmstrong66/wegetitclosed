<style>
.ams-hub-wrapper {
  --ams-navy: #1a2b5e;
  --ams-blue: #1a2b5e;
  --ams-sky:  #c8102e;
  --ams-sand: #f1f5f9;
  --ams-white: #ffffff;
  --ams-gray: #f8fafc;

  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: var(--ams-navy);
  line-height: 1.6;
  width: 100%;
  overflow-x: hidden;
  margin-bottom: 80px;
}
.ams-hub-wrapper * { box-sizing: border-box; }

.ams-section { padding: 40px 20px; width: 100%; }
.ams-inner { max-width: 1200px; margin: 0 auto; }

.ams-spacer { height: 60px; width: 100%; }
@media (max-width: 768px) { .ams-spacer { height: 40px; } }

.ams-hub-wrapper h1,
.ams-hub-wrapper h2.ams-main-title {
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 800;
  text-align: left;
  color: var(--ams-navy);
  margin-bottom: 15px;
  letter-spacing: -1.5px;
  line-height: 1.1;
  border-left: none;
  padding-left: 0;
  margin-top: 10px;
}

.ams-hub-wrapper h2 {
  font-size: clamp(1.75rem, 4vw, 2.4rem);
  font-weight: 700;
  margin-top: 35px;
  margin-bottom: 1rem;
  letter-spacing: -0.5px;
  color: var(--ams-navy);
  text-align: left;
  line-height: 1.3;
  border-left: 5px solid var(--ams-sky);
  padding-left: 15px;
}

.ams-hub-wrapper h3 {
  font-size: clamp(1.4rem, 3vw, 1.8rem);
  font-weight: 600;
  margin-bottom: 15px;
  color: var(--ams-navy);
  margin-top: 20px;
  border-left: 5px solid var(--ams-sky);
  padding-left: 15px;
  line-height: 1.3;
}

.ams-card-title {
  font-size: 1.3rem !important;
  font-weight: 700 !important;
  margin: 0 0 12px 0 !important;
  border-left: none !important;
  padding-left: 0 !important;
  color: var(--ams-navy);
  display: block;
  line-height: 1.2;
}

.ams-hub-wrapper p {
  font-size: 1.1rem;
  color: #475569;
  margin-bottom: 1.5rem;
  line-height: 1.7;
}

.ams-subhead {
  font-size: 1.15rem;
  color: #475569;
  margin-bottom: 35px;
  max-width: 900px;
  text-align: left;
}

/* --- Proof Bar --- */
.ams-proof-bar {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  margin: 30px 0 50px 0;
  padding: 30px 25px;
  background: var(--ams-gray);
  border-radius: 12px;
  border: 1px solid #e2e8f0;
}

.ams-proof-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 8px;
}

.ams-proof-item span {
  font-weight: 800;
  color: var(--ams-sky);
  font-size: 1.5rem;
  line-height: 1;
}

.ams-proof-item label {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--ams-navy);
  text-transform: uppercase;
  letter-spacing: 1px;
}

@media (max-width: 768px) {
  .ams-proof-bar {
    grid-template-columns: 1fr;
    padding: 25px;
    gap: 30px;
  }
  .ams-proof-item span { font-size: 1.8rem; }
}

/* --- Options Grid --- */
.ams-options-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 30px;
  margin-bottom: 40px;
}

@media (min-width: 650px) and (max-width: 1023px) {
  .ams-options-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .ams-options-grid { grid-template-columns: repeat(3, 1fr); }
}

.ams-option-card {
  background: white;
  padding: 40px 30px;
  border: 1px solid #e2e8f0;
  border-bottom: 4px solid var(--ams-sky);
  border-radius: 12px;
  text-align: left;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
}

.ams-option-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(26, 43, 94, 0.08);
}

/* --- Icons --- */
.ams-icon-box {
  width: 65px;
  height: 65px;
  margin-bottom: 25px;
  border-radius: 14px;
  background: linear-gradient(145deg, #ffffff, #f1f5f9);
  box-shadow: 4px 4px 10px #e2e8f0, -4px -4px 10px #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ams-lux-svg {
  width: 32px;
  height: 32px;
  fill: url(#amsGradient);
}

/* --- Buttons --- */
.ams-btn-text {
  color: var(--ams-navy);
  font-weight: 700;
  text-decoration: none;
  text-transform: uppercase;
  font-size: 0.85rem;
  letter-spacing: 1px;
  border-bottom: 2px solid var(--ams-sky);
  padding-bottom: 4px;
  align-self: flex-start;
  margin-top: 20px;
  transition: color 0.2s;
}
.ams-btn-text:hover { color: var(--ams-sky); }

.ams-btn-primary, .ams-btn-outline {
  padding: 18px 28px;
  font-weight: 800;
  text-decoration: none;
  text-transform: uppercase;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  font-size: 0.95rem;
  width: 100%;
  letter-spacing: 0.8px;
}

@media (min-width: 768px) {
  .ams-btn-primary, .ams-btn-outline { width: auto; min-width: 300px; }
}

/* --- Discreet App CTA --- */
.ams-auth-btn.primary {
  display: inline-block;
  font-size: 0.85rem;
  font-weight: 700;
  color: #475569;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  text-decoration: none;
  padding: 8px 16px;
  background-color: var(--ams-gray);
  border: 1px solid #e2e8f0;
  border-radius: 6px;
  margin-top: -15px;
  margin-bottom: 30px;
  transition: all 0.3s ease;
}
.ams-auth-btn.primary:hover {
  background-color: var(--ams-blue);
  color: var(--ams-white);
  border-color: var(--ams-blue);
}

/* --- Limit Box --- */
.ams-limit-box {
  background: var(--ams-navy);
  padding: 50px 40px;
  border-radius: 16px;
  margin: 80px 0;
  text-align: center;
  border-top: 5px solid var(--ams-sky);
}
.ams-limit-box h4 {
  color: var(--ams-sky);
  text-transform: uppercase;
  margin-bottom: 15px;
  font-weight: 800;
}
.ams-limit-box p { color: #fff !important; margin: 0; font-size: 1.2rem; }

/* --- Final CTA --- */
.ams-cta-wrapper {
  background-image: linear-gradient(rgba(10, 15, 28, 0.97), rgba(10, 15, 28, 0.94)), url('/images/florida-mortgage-background.webp');
  background-size: cover;
  background-position: center;
  background-color: var(--ams-navy);
  text-align: center;
  padding: 100px 30px;
  margin-top: 40px;
  border-radius: 16px;
  color: var(--ams-white);
}

.ams-cta-inner h2 {
  color: var(--ams-white) !important;
  font-size: clamp(2rem, 4vw, 2.8rem);
  margin-bottom: 20px;
  border-left: none;
  padding-left: 0;
  text-align: center;
}

.ams-cta-inner p {
  color: #cbd5e1 !important;
  font-size: 1.25rem;
  max-width: 800px;
  margin: 0 auto 40px auto;
}

.ams-btn-container {
  display: flex;
  flex-direction: column;
  gap: 20px;
  align-items: center;
  justify-content: center;
  margin-top: 40px;
}
@media (min-width: 768px) { .ams-btn-container { flex-direction: row; } }

.ams-btn-primary {
  background: var(--ams-sky);
  color: var(--ams-white) !important;
  border: 2px solid var(--ams-sky);
}
.ams-btn-primary:hover {
  background: #a50d26;
  border-color: #a50d26;
  transform: translateY(-2px);
}

.ams-btn-outline {
  background: transparent;
  color: var(--ams-white) !important;
  border: 2px solid var(--ams-white);
}
.ams-btn-outline:hover {
  background: var(--ams-white);
  color: var(--ams-navy) !important;
  transform: translateY(-2px);
}

/* --- City Chips --- */
.ams-chip-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 12px;
  margin-bottom: 50px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.ams-chip-scroll::-webkit-scrollbar { display: none; }

.ams-chip {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 22px;
  background: var(--ams-white);
  border: 1px solid #e2e8f0;
  border-bottom: 3px solid var(--ams-sky);
  border-radius: 50px;
  text-decoration: none !important;
  color: var(--ams-navy);
  font-weight: 700;
  font-size: 0.9rem;
  transition: all 0.2s;
  white-space: nowrap;
}
.ams-chip:hover {
  background: var(--ams-sky);
  color: var(--ams-white) !important;
  border-color: var(--ams-sky);
}
.ams-chip svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }

/* --- NMLS Disclosure --- */
.ams-nmls { font-size: 0.78rem; color: #94a3b8; margin-top: 30px; line-height: 1.6; }
</style>

