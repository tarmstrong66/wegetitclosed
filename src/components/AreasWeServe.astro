---
interface AreaItem {
  name: string;
  url: string;
}

interface Props {
  states: AreaItem[];
  cities?: AreaItem[];
}

const { states, cities } = Astro.props;
---

<section class="areas-we-serve" aria-label="Areas we serve">
  <div class="container">
    <h2 class="section-heading">Areas We Serve</h2>

    <div class="row-group">
      <span class="row-label">States</span>
      <div class="pill-row">
        {states.map(({ name, url }) => (
          <a href={url} class="pill pill--state">{name}</a>
        ))}
      </div>
    </div>

    {cities && cities.length > 0 && (
      <div class="row-group">
        <span class="row-label">Cities</span>
        <div class="pill-row">
          {cities.map(({ name, url }) => (
            <a href={url} class="pill pill--city">{name}</a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
.areas-we-serve {
  background: var(--color-off-white);
  border-top: 1px solid var(--color-gray-subtle);
  padding: var(--space-12) 0;
}

.section-heading {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  color: var(--color-navy);
  margin-bottom: var(--space-8);
}

.row-group {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
}

.row-group:last-child {
  margin-bottom: 0;
}

.row-label {
  flex-shrink: 0;
  width: 4rem;
  padding-top: 10px;
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--color-gray-mid);
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.pill {
  display: inline-block;
  padding: 8px 18px;
  border-radius: var(--radius-pill);
  font-size: var(--text-sm);
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.18s, color 0.18s, border-color 0.18s;
}

.pill--state {
  background: var(--color-white);
  color: var(--color-navy);
  border: 1px solid oklch(22% 0.06 260 / 0.18);
  border-bottom: 2px solid var(--color-navy);
}

.pill--state:hover {
  background: var(--color-navy);
  color: var(--color-white);
  border-color: var(--color-navy);
}

.pill--city {
  background: var(--color-white);
  color: var(--color-navy);
  border: 1px solid oklch(52% 0.22 25 / 0.25);
  border-bottom: 2px solid var(--color-red);
}

.pill--city:hover {
  background: var(--color-red);
  color: var(--color-white);
  border-color: var(--color-red);
}

@media (max-width: 640px) {
  .row-group {
    flex-direction: column;
    gap: var(--space-2);
  }

  .row-label {
    width: auto;
    padding-top: 0;
  }
}
</style>
