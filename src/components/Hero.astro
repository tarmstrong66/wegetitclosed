---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaUrl: string;
  secondaryCtaText?: string;
  secondaryCtaUrl?: string;
}
const { headline, subheadline, ctaText, ctaUrl, secondaryCtaText, secondaryCtaUrl } = Astro.props;
---
<section class="hero">
  <div class="hero-pattern" aria-hidden="true"></div>
  <div class="container hero-content">
    <h1>{headline}</h1>
    <p class="hero-sub">{subheadline}</p>
    <div class="hero-ctas">
      <a href={ctaUrl} class="btn-primary">{ctaText}</a>
      {secondaryCtaText && secondaryCtaUrl && (
        <a href={secondaryCtaUrl} class="btn-ghost">{secondaryCtaText}</a>
      )}
    </div>
    <p class="hero-note">Subject to credit, income, property, program, and lender guidelines.</p>
  </div>
</section>

<style>
.hero {
  position: relative;
  background: url('/images/we-get-it-closed-hero-bg.webp') center/cover no-repeat;
  overflow: hidden;
  padding: var(--space-24) 0 var(--space-20);
}
.hero-pattern {
  position: absolute; inset: 0;
  background: linear-gradient(
    to right,
    oklch(22% 0.06 260 / 0.85) 0%,
    oklch(22% 0.06 260 / 0.60) 50%,
    oklch(22% 0.06 260 / 0.25) 100%
  );
}
.hero-content {
  position: relative; z-index: 1;
  max-width: 780px;
}
.hero-content h1 {
  color: var(--color-white);
  font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
  margin-bottom: var(--space-6);
  font-weight: 700;
}
.hero-sub {
  color: oklch(80% 0.02 260);
  font-size: clamp(var(--text-lg), 2.5vw, var(--text-2xl));
  margin-bottom: var(--space-8);
  max-width: 58ch;
}
.hero-ctas {
  display: flex; gap: var(--space-4); flex-wrap: wrap;
  margin-bottom: var(--space-6);
}
.hero-note {
  font-size: var(--text-xs); color: oklch(55% 0.01 260);
  max-width: none;
}
</style>
