---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  number?: string;
}
const { icon, title, description, href, number } = Astro.props;
---
<a href={href} class="intent-card">
  <div class="card-top">
    <div class="card-icon">
      <Icon name={icon as any} size={22} />
    </div>
    {number && <span class="card-number" aria-hidden="true">{number}</span>}
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="card-link">
    Get Started
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
.intent-card {
  display: flex;
  flex-direction: column;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-gray-subtle);
  padding: var(--space-6);
  text-decoration: none;
  transition: transform 200ms ease-out, box-shadow 200ms ease-out, border-color 200ms ease-out;
}
.intent-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
  border-color: oklch(52% 0.22 25 / 0.3);
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-6);
}

.card-icon {
  width: 44px;
  height: 44px;
  background: oklch(95% 0.03 255);
  border: 1px solid oklch(87% 0.05 255);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-number {
  font-family: var(--font-body);
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-gray-subtle);
  line-height: 1;
  letter-spacing: -0.02em;
}

.intent-card h3 {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--color-navy);
  margin-bottom: var(--space-2);
}

.intent-card p {
  font-size: var(--text-sm);
  color: var(--color-gray-mid);
  flex: 1;
  margin-bottom: var(--space-6);
  line-height: 1.6;
  max-width: none;
}

.card-link {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  color: var(--color-red);
  font-size: var(--text-sm);
  font-weight: 600;
  margin-top: auto;
  transition: gap 150ms ease-out;
}
.intent-card:hover .card-link {
  gap: var(--space-2);
}
</style>
