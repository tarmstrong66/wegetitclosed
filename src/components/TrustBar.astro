---
---
<div class="trust-bar">
  <div class="container">
    <div class="proof-grid">
      <div class="proof-item">
        <span class="proof-value" data-count="40" data-suffix="+ Lenders">40+ Lenders</span>
        <label class="proof-label">Top Wholesale Rates</label>
      </div>
      <div class="proof-item">
        <span class="proof-value" data-count="40" data-suffix="+ Years">40+ Years</span>
        <label class="proof-label">Combined Experience</label>
      </div>
      <div class="proof-item">
        <span class="proof-value" data-count="4.8" data-suffix=" Stars" data-decimals="1">4.8 Stars</span>
        <label class="proof-label">135 Google Reviews</label>
      </div>
    </div>
  </div>
</div>

<style>
.trust-bar {
  background: var(--color-white);
  padding: var(--space-8) 0 var(--space-10);
}
.proof-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
  background: var(--color-gray-subtle);
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: var(--space-8) var(--space-6);
}
@media (max-width: 768px) {
  .proof-grid {
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
}
.proof-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: var(--space-2);
}
.proof-value {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--text-2xl);
  color: var(--color-red);
  line-height: 1;
}
.proof-label {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-navy);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.proof-value[data-count]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      observer.unobserve(entry.target);
      const el = entry.target as HTMLElement;
      const target = parseFloat(el.dataset.count!);
      const suffix = el.dataset.suffix ?? '';
      const decimals = parseInt(el.dataset.decimals ?? '0');
      const duration = 1200;
      const start = performance.now();
      const tick = (now: number) => {
        const elapsed = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - elapsed, 3);
        el.textContent = (eased * target).toFixed(decimals) + suffix;
        if (elapsed < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });
  }, { threshold: 0.3 });
  items.forEach(el => observer.observe(el));
</script>
