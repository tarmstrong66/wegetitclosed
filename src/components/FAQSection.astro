---
interface FAQ {
  question: string;
  answer: string;
}
interface Props {
  faqs: FAQ[];
  heading?: string;
  alwaysOpen?: boolean;
}
const { faqs, heading = 'Frequently Asked Questions', alwaysOpen = false } = Astro.props;
---
<section class="faq-section">
  <div class="container-narrow">
    <h2>{heading}</h2>
    <div class="faq-list">
      {alwaysOpen ? faqs.map((faq) => (
        <div class="faq-item">
          <p class="faq-question">{faq.question}</p>
          <p class="faq-answer" set:html={faq.answer} />
        </div>
      )) : faqs.map((faq, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-summary">
            <span>{faq.question}</span>
            <svg class="faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <p class="faq-answer" set:html={faq.answer} />
        </details>
      ))}
    </div>
  </div>
</section>

<style>
.faq-section {
  padding: var(--space-16) 0;
  background: var(--color-off-white);
  border-top: 1px solid var(--color-gray-subtle);
}

.faq-section h2 {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  color: var(--color-navy);
  margin-bottom: var(--space-10);
  text-align: center;
}

.faq-list {
  display: flex;
  flex-direction: column;
}

.faq-item {
  padding: var(--space-10) 0;
  border-bottom: 1px solid var(--color-gray-subtle);
}

.faq-item:first-child {
  border-top: 1px solid var(--color-gray-subtle);
}

/* Always-open static style */
.faq-question {
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-navy);
  line-height: 1.4;
  margin: 0 0 var(--space-4) 0;
}

/* Accordion summary style */
.faq-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  cursor: pointer;
  list-style: none;
  user-select: none;
  margin-bottom: 0;
}

.faq-summary::-webkit-details-marker { display: none; }

.faq-summary span {
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-navy);
  line-height: 1.4;
}

.faq-icon {
  flex-shrink: 0;
  color: var(--color-navy);
  opacity: 0.5;
  transition: transform 250ms ease-out;
}

details[open] .faq-icon {
  transform: rotate(180deg);
}

details[open] .faq-summary {
  margin-bottom: var(--space-3);
}

.faq-answer {
  color: var(--color-gray-body);
  font-size: var(--text-base);
  line-height: 1.7;
  margin: 0;
}

.faq-answer a {
  color: var(--color-navy);
  text-decoration: underline;
}

.faq-answer a:hover { color: var(--color-red); }
</style>
