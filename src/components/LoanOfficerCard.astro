---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  title?: string;
  image: ImageMetadata;
  applyUrl?: string;
}

const { name, title = 'Loan Officer', image, applyUrl = '/loan-officers/' } = Astro.props;
---

<div class="lo-card">
  <div class="lo-photo-wrap">
    <Image
      src={image}
      alt={`${name}, ${title} at American Mortgage Services`}
      width={120}
      height={120}
      format="webp"
      quality={85}
      class="lo-photo"
    />
  </div>
  <div class="lo-info">
    <p class="lo-name">{name}</p>
    <p class="lo-title">{title}</p>
    <a href={applyUrl} class="lo-apply btn-secondary">Apply</a>
  </div>
</div>

<style>
.lo-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-white);
  border: 1px solid var(--color-gray-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 150ms ease-out, box-shadow 150ms ease-out;
}
.lo-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}

.lo-photo-wrap {
  width: 120px;
  height: 120px;
  margin-top: var(--space-4);
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-off-white);
  flex-shrink: 0;
}
.lo-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.lo-info {
  padding: var(--space-4);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
}

.lo-name {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-navy);
  margin: 0;
  max-width: none;
}

.lo-title {
  font-size: var(--text-xs);
  color: var(--color-gray-mid);
  margin: 0 0 var(--space-3);
  max-width: none;
}

.lo-apply {
  font-size: var(--text-xs);
  padding: var(--space-2) var(--space-4);
  text-decoration: none;
}
</style>
