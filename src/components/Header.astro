---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/AMS-Logo-300x100-1 (1).webp';
---
<header class="site-header" id="site-header">
  <div class="header-inner container">

    <a href="/" class="logo" aria-label="American Mortgage Services: We Get It Closed">
      <Image
        src={logoImg}
        alt="American Mortgage Services â€” We Get It Closed"
        width={180}
        height={60}
        loading="eager"
        decoding="async"
        class="logo-img"
      />
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">

        <li class="has-dropdown">
          <button class="dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            Programs
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="dropdown" role="menu">
            <div class="dropdown-grid">
              <div class="dropdown-col">
                <span class="dropdown-label">Purchase</span>
                <a href="/programs/fha-loans/" role="menuitem">FHA Loans</a>
                <a href="/programs/va-loans/" role="menuitem">VA Loans</a>
                <a href="/programs/conventional-loans/" role="menuitem">Conventional Loans</a>
                <a href="/programs/usda-loans/" role="menuitem">USDA Loans</a>
                <a href="/programs/jumbo-loans/" role="menuitem">Jumbo Loans</a>
                <a href="/programs/first-time-homebuyer-loans/" role="menuitem">First-Time Homebuyer</a>
              </div>
              <div class="dropdown-col">
                <span class="dropdown-label">Specialty</span>
                <a href="/programs/bank-statement-loans/" role="menuitem">Bank Statement Loans</a>
                <a href="/programs/investor-loans/" role="menuitem">Investor Loans</a>
                <a href="/programs/renovation-loans/" role="menuitem">Renovation Loans</a>
                <a href="/programs/reverse-mortgages/" role="menuitem">Reverse Mortgages</a>
                <a href="/programs/low-credit-score-mortgage-options/" role="menuitem">Low Credit Score Options</a>
              </div>
              <div class="dropdown-col">
                <span class="dropdown-label">Refinance</span>
                <a href="/programs/refinance-loans/" role="menuitem">Refinance Loans</a>
                <a href="/programs/cash-out-refinance/" role="menuitem">Cash-Out Refinance</a>
                <span class="dropdown-label" style="margin-top:1rem;">All Programs</span>
                <a href="/programs/" role="menuitem">View All Programs</a>
              </div>
            </div>
          </div>
        </li>

        <li class="has-dropdown">
          <button class="dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            States
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="dropdown dropdown--states" role="menu">
            <div class="dropdown-col">
              <span class="dropdown-label">Where We Lend</span>
              <a href="/alabama-mortgage/" role="menuitem">Alabama</a>
              <a href="/florida-mortgage/" role="menuitem">Florida</a>
              <a href="/florida-mortgage/tampa/" role="menuitem" style="padding-left:1rem;font-size:var(--text-xs);color:var(--color-gray-mid);">â†³ Tampa</a>
              <a href="/georgia-mortgage/" role="menuitem">Georgia</a>
              <a href="/louisiana-mortgage/" role="menuitem">Louisiana</a>
              <a href="/michigan-mortgage/" role="menuitem">Michigan</a>
              <a href="/tennessee-mortgage/" role="menuitem">Tennessee</a>
            </div>
          </div>
        </li>

        <li class="has-dropdown">
          <button class="dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            About Us
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="dropdown dropdown--about" role="menu">
            <div class="dropdown-col">
              <a href="/about/" role="menuitem">About American Mortgage Services</a>
              <a href="/the-team/" role="menuitem">The Team</a>
              <a href="/loan-officers/" role="menuitem">Loan Officers</a>
            </div>
          </div>
        </li>

      </ul>
    </nav>

    <div class="header-actions">
      <a href="/loan-officers/" class="btn-apply">Apply Now</a>
      <a href="tel:8888389330" class="btn-phone" aria-label="Call us at (888) 838-9330">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C9.6 21 3 14.4 3 6c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        (888) 838-9330
      </a>
    </div>

    <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span><span></span><span></span>
    </button>

  </div>
</header>

<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <div class="mobile-nav-inner">
    <button class="mobile-close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <nav aria-label="Mobile navigation">
      <a href="/">Home</a>
      <a href="/programs/">All Loan Programs</a>
      <a href="/programs/fha-loans/">FHA Loans</a>
      <a href="/programs/va-loans/">VA Loans</a>
      <a href="/programs/conventional-loans/">Conventional Loans</a>
      <a href="/programs/usda-loans/">USDA Loans</a>
      <a href="/programs/first-time-homebuyer-loans/">First-Time Homebuyer</a>
      <a href="/programs/refinance-loans/">Refinance</a>
      <a href="/programs/cash-out-refinance/">Cash-Out Refinance</a>
      <a href="/alabama-mortgage/">Alabama</a>
      <a href="/florida-mortgage/">Florida</a>
      <a href="/georgia-mortgage/">Georgia</a>
      <a href="/louisiana-mortgage/">Louisiana</a>
      <a href="/michigan-mortgage/">Michigan</a>
      <a href="/tennessee-mortgage/">Tennessee</a>
      <a href="/about/">About Us</a>
      <a href="/the-team/">The Team</a>
      <a href="/loan-officers/">Loan Officers</a>
    </nav>
    <a href="/loan-officers/" class="btn-primary mobile-cta">Apply Now</a>
    <a href="tel:8888389330" class="mobile-phone">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C9.6 21 3 14.4 3 6c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
      (888) 838-9330
    </a>
  </div>
</div>

<script>
const header = document.getElementById('site-header')!;
const hamburger = document.querySelector('.hamburger') as HTMLButtonElement;
const mobileNav = document.getElementById('mobile-nav')!;
const mobileClose = document.querySelector('.mobile-close') as HTMLButtonElement;

window.addEventListener('scroll', () => {
  header.classList.toggle('scrolled', window.scrollY > 20);
});

function openMenu() {
  mobileNav.classList.add('open');
  mobileNav.setAttribute('aria-hidden', 'false');
  hamburger.setAttribute('aria-expanded', 'true');
  document.body.style.overflow = 'hidden';
}
function closeMenu() {
  mobileNav.classList.remove('open');
  mobileNav.setAttribute('aria-hidden', 'true');
  hamburger.setAttribute('aria-expanded', 'false');
  document.body.style.overflow = '';
}

hamburger.addEventListener('click', openMenu);
mobileClose.addEventListener('click', closeMenu);

const triggers = document.querySelectorAll('.dropdown-trigger');
triggers.forEach(trigger => {
  trigger.addEventListener('click', () => {
    const expanded = trigger.getAttribute('aria-expanded') === 'true';
    triggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
    trigger.setAttribute('aria-expanded', String(!expanded));
  });
});
document.addEventListener('click', (e) => {
  if (!(e.target as Element).closest('.has-dropdown')) {
    triggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
  }
});
</script>

<style>
.site-header {
  position: sticky; top: 0; z-index: 100;
  background: var(--color-white);
  transition: box-shadow 150ms ease-out;
}
.site-header.scrolled { box-shadow: var(--shadow-md); }

.header-inner {
  display: flex; align-items: center; gap: var(--space-6);
  height: 72px;
}

.logo { text-decoration: none; display: flex; align-items: center; flex-shrink: 0; }
.logo-img {
  display: block;
  height: 48px;
  width: auto;
  max-width: 180px;
  object-fit: contain;
}

.main-nav { margin-left: auto; }
.nav-list {
  display: flex; align-items: center; gap: var(--space-1);
  list-style: none;
}
.nav-list > li > a, .dropdown-trigger {
  display: flex; align-items: center; gap: 4px;
  padding: var(--space-2) var(--space-3);
  font-family: var(--font-body); font-weight: 500; font-size: var(--text-sm);
  color: var(--color-navy); text-decoration: none;
  border-radius: var(--radius-sm); border: none; background: none; cursor: pointer;
  transition: color 150ms ease-out, background 150ms ease-out;
  white-space: nowrap;
}
.nav-list > li > a:hover, .dropdown-trigger:hover { color: var(--color-red); background: var(--color-off-white); }

.has-dropdown { position: relative; }
.dropdown {
  display: none; position: absolute; top: calc(100% + 8px); left: 50%;
  transform: translateX(-50%);
  background: var(--color-white); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg); padding: var(--space-6);
  min-width: 600px; z-index: 200;
}
.dropdown--states { min-width: 200px; }
.dropdown--about { min-width: 260px; }
.dropdown-trigger[aria-expanded="true"] + .dropdown { display: block; }
.dropdown-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
.dropdown-col { display: flex; flex-direction: column; gap: var(--space-1); }
.dropdown-label {
  font-size: var(--text-xs); font-weight: 600; color: var(--color-gray-mid);
  text-transform: uppercase; letter-spacing: 0.06em;
  margin-bottom: var(--space-1); display: block;
}
.dropdown a {
  font-size: var(--text-sm); color: var(--color-navy); text-decoration: none;
  font-weight: 500; padding: var(--space-1) 0;
  transition: color 150ms ease-out;
}
.dropdown a:hover { color: var(--color-red); }

.header-actions {
  display: flex; align-items: center; gap: var(--space-3); flex-shrink: 0;
}

.btn-apply {
  background: var(--color-red); color: var(--color-white);
  font-family: var(--font-body); font-weight: 600; font-size: var(--text-sm);
  padding: 10px 20px; border-radius: var(--radius-pill);
  text-decoration: none; transition: background 150ms ease-out;
  white-space: nowrap;
}
.btn-apply:hover { background: var(--color-red-hover); color: var(--color-white); }

.btn-phone {
  display: flex; align-items: center; gap: 6px;
  padding: 10px 16px; border-radius: var(--radius-pill);
  border: 1.5px solid oklch(22% 0.06 260 / 0.2);
  font-family: var(--font-body); font-weight: 600; font-size: var(--text-sm);
  color: var(--color-navy); text-decoration: none;
  white-space: nowrap; transition: border-color 150ms, color 150ms, background 150ms;
}
.btn-phone:hover {
  border-color: var(--color-navy);
  background: var(--color-off-white);
  color: var(--color-navy);
}
.btn-phone svg { flex-shrink: 0; }

.hamburger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: var(--space-2);
}
.hamburger span {
  display: block; width: 24px; height: 2px;
  background: var(--color-navy); border-radius: 2px;
  transition: all 150ms ease-out;
}

.mobile-nav {
  display: none; position: fixed; inset: 0; z-index: 200;
  background: var(--color-navy);
}
.mobile-nav.open { display: block; }
.mobile-nav-inner {
  display: flex; flex-direction: column; padding: var(--space-6);
  height: 100%; overflow-y: auto;
}
.mobile-close {
  align-self: flex-end; background: none; border: none;
  color: var(--color-white); cursor: pointer; padding: var(--space-2);
  margin-bottom: var(--space-4);
}
.mobile-nav-inner nav { display: flex; flex-direction: column; gap: var(--space-1); flex: 1; }
.mobile-nav-inner nav a {
  color: var(--color-white); text-decoration: none;
  font-size: var(--text-lg); font-weight: 500;
  padding: var(--space-3) 0; border-bottom: 1px solid var(--color-navy-light);
  transition: color 150ms ease-out;
}
.mobile-nav-inner nav a:hover { color: var(--color-gold); }
.mobile-cta {
  display: block; text-align: center;
  margin-top: var(--space-6);
  background: var(--color-red); color: var(--color-white);
  font-family: var(--font-body); font-weight: 600; font-size: var(--text-base);
  padding: 14px 24px; border-radius: var(--radius-pill);
  text-decoration: none; transition: background 150ms;
}
.mobile-cta:hover { background: var(--color-red-hover); color: var(--color-white) !important; }
.mobile-phone {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  color: var(--color-gold); text-decoration: none;
  margin-top: var(--space-4); font-size: var(--text-base); font-weight: 600;
}
.mobile-phone:hover { color: var(--color-white) !important; }

@media (max-width: 1024px) {
  .main-nav { display: none; }
  .header-actions { display: none; }
  .hamburger { display: flex; margin-left: auto; }
}
</style>
